# ─── Tatum ────────────────────────────────────────────────────────────────────
# Get a free key at https://dashboard.tatum.io
TATUM_API_KEY=

# ─── Sui ──────────────────────────────────────────────────────────────────────
# "testnet" or "mainnet"
SUI_NETWORK=testnet

# The principal's Sui wallet address (portfolio to analyze)
PRINCIPAL_ADDRESS=

# The agent's Sui wallet keypair (hex-encoded private key)
# Generate with: sui keytool generate ed25519
AGENT_PRIVATE_KEY=

# Delegation object ID (created by create_and_fund Move entry fn)
# Leave blank during Step 0 — the preflight will create a mock delegation
DELEGATION_OBJECT_ID=

# ─── Walrus ───────────────────────────────────────────────────────────────────
# Number of epochs to store blobs (1 epoch ≈ 2 weeks on mainnet)
# Use a buffer so blobs outlive the judging window
WALRUS_EPOCHS=5

# "false" for deletable blobs (cheaper), "true" for permanent
WALRUS_PERMANENT=false

# Walrus publisher endpoint (testnet default)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ─── Seal ─────────────────────────────────────────────────────────────────────
# Seal package IDs (do not change unless Mysten redeploys)
SEAL_PACKAGE_ID_TESTNET=0x4016869413374eaa71df2a043d1660ed7bc927ab7962831f8b07efbc7efdb2c3
SEAL_PACKAGE_ID_MAINNET=0xcb83a248bda5f7a0a431e6bf9e96d184e604130ec5218696e3f1211113b447b7

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Used by the agent runtime for treasury analysis reasoning
ANTHROPIC_API_KEY=

# ─── Contract ─────────────────────────────────────────────────────────────────
# Set after deploying the Move package
PROVENANT_PACKAGE_ID=
